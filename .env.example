# Copy to .env and edit. Values here are SAFE DEFAULTS for the bundled
# "web + pgvector" docker-compose stack. For local (non-docker) runs without a
# database, set storage/checkpointer/vector backends to sqlite (see bottom note).

# ---- LLM provider (pick one) ------------------------------------------------
# 'fake' is offline and needs no secrets — good for first boot / smoke tests.
AGENTKIT_LLM_PROVIDER=fake
# Internal gateway provider (customer_band):
#   AGENTKIT_LLM_PROVIDER=customer_band
#   AI_CLIENT_ID=
#   AI_CLIENT_SECRET=
#   AI_APP_KEY=
# OpenAI-compatible endpoint:
#   AGENTKIT_LLM_PROVIDER=openai
#   AGENTKIT_OPENAI_BASE_URL=
#   AGENTKIT_OPENAI_API_KEY=
#   AGENTKIT_OPENAI_MODEL=
AGENTKIT_LLM_MAX_TOKENS=4096        # 推理模型建议 4096~8192，think 长就再调大
AGENTKIT_LLM_TIMEOUT_SECONDS=120    # 推理模型更慢，默认 30s 容易超时，顺手调大
# 关闭推理模型的 <think> 输出（Qwen3/vLLM/SGLang 等），更快更省、避免 JSON 被截断。
# 仅对 openai provider 生效；端点不认这个参数时无副作用（如 DeepSeek-R1 无法关闭）。
AGENTKIT_OPENAI_DISABLE_THINKING=true
# 需要更细控制时，用原始 JSON 透传到请求体 extra_body（会合并到上面的开关之上）：
#   AGENTKIT_OPENAI_EXTRA_BODY={"enable_thinking": false}
#   AGENTKIT_OPENAI_EXTRA_BODY={"chat_template_kwargs": {"enable_thinking": false}}

# ---- Web console security ---------------------------------------------------
# Auth is ON by default. Generate strong values, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AGENTKIT_WEB_AUTH_DISABLED=false
AGENTKIT_WEB_AUTH_TOKEN=
AGENTKIT_WEB_SECRET_KEY=
# Cookies are sent only over HTTPS when true. The compose stack serves plain
# HTTP on :8501, so this is false; set it to true once you put TLS in front.
AGENTKIT_WEB_COOKIE_SECURE=false
# Optional trusted business roles for shared-token login. Leave empty to use the
# tenant's local/demo default roles.
AGENTKIT_WEB_TOKEN_BUSINESS_ROLES=
# Production SSO: a reverse proxy can forward business roles separately from
# console RBAC roles (recommended for enterprise deployments).
AGENTKIT_AUTH_PROXY_BUSINESS_ROLES_HEADER=X-Forwarded-Business-Roles
AGENTKIT_AUTH_PROXY_DEFAULT_BUSINESS_ROLES=

# ---- Runtime behaviour (sensible defaults) ----------------------------------
AGENTKIT_STORAGE_BACKEND=postgres
AGENTKIT_APPROVAL_CHECKPOINTER=postgres
AGENTKIT_DETERMINISTIC_FASTPATH=true
AGENTKIT_COMBINED_INTENT_ROUTE=true
AGENTKIT_TOOL_MAX_WORKERS=32

# ---- Long-term memory vector store (PostgreSQL + pgvector) -------------------
AGENTKIT_VECTOR_STORE_BACKEND=postgres
AGENTKIT_PG_DATABASE=agentkit
AGENTKIT_PG_USER=agentkit
# REQUIRED: the db service refuses to start without this. Use a strong value.
AGENTKIT_PG_PASSWORD=change-me-strong-password
# For docker-compose these are overridden to host=db / sslmode=disable; the
# values below apply to local (non-docker) runs against your own Postgres.
AGENTKIT_PG_HOST=localhost
AGENTKIT_PG_PORT=5432
AGENTKIT_PG_SSLMODE=disable

# Running locally WITHOUT a database? Comment out the postgres block above and
# use SQLite instead (zero external dependencies):
#   AGENTKIT_STORAGE_BACKEND=sqlite
#   AGENTKIT_APPROVAL_CHECKPOINTER=sqlite
#   AGENTKIT_VECTOR_STORE_BACKEND=sqlite

# ---- Enterprise knowledge-base RAG (Chroma) --------------------------------
# Disabled by default. Enable after ingesting docs with:
#   agentkit --tenant company_alpha rag-ingest ./knowledge --ocr
#   agentkit --tenant company_alpha rag-query "refund policy" --roles support
AGENTKIT_RAG_ENABLED=false
AGENTKIT_RAG_STORE_BACKEND=chroma
AGENTKIT_RAG_CHROMA_PATH=data/chroma
AGENTKIT_RAG_CHROMA_COLLECTION=agentkit_knowledge
AGENTKIT_RAG_TOP_K=5
AGENTKIT_RAG_CONTEXT_CAP_TOKENS=1000
AGENTKIT_RAG_CHUNK_MAX_CHARS=1200
AGENTKIT_RAG_CHUNK_OVERLAP_CHARS=120
AGENTKIT_RAG_TABLE_CHUNK_MAX_CHARS=900
AGENTKIT_RAG_OCR_CHUNK_MAX_CHARS=900
AGENTKIT_RAG_KEYWORD_WEIGHT=0.4
AGENTKIT_RAG_VECTOR_WEIGHT=0.6
AGENTKIT_RAG_MIN_VECTOR_SCORE=0.0
# none = cheapest; llm = better for terse/ambiguous user questions, costs one LLM call.
AGENTKIT_RAG_QUERY_REWRITE=none
AGENTKIT_RAG_QUERY_REWRITE_MAX=3
# none = cheapest; keyword = deterministic exact-term boost; llm = best quality but costs one LLM call.
AGENTKIT_RAG_RERANKER=none
AGENTKIT_RAG_RERANK_CANDIDATES=12
# OCR needs agentkit[rag] plus a system tesseract binary/language packs.
AGENTKIT_RAG_OCR_ENABLED=false
AGENTKIT_RAG_OCR_LANGUAGES=eng+chi_sim
