# Copy to .env and edit. Values here are SAFE DEFAULTS for the bundled
# "web + pgvector" docker-compose stack. For local (non-docker) runs without a
# database, set AGENTKIT_VECTOR_STORE_BACKEND=sqlite (see the bottom note).

# ---- LLM provider (pick one) ------------------------------------------------
# 'fake' is offline and needs no secrets — good for first boot / smoke tests.
AGENTKIT_LLM_PROVIDER=fake
# Internal gateway provider (customer_band):
#   AGENTKIT_LLM_PROVIDER=customer_band
#   AI_CLIENT_ID=
#   AI_CLIENT_SECRET=
#   AI_APP_KEY=
# OpenAI-compatible endpoint:
#   AGENTKIT_LLM_PROVIDER=openai
#   AGENTKIT_OPENAI_BASE_URL=
#   AGENTKIT_OPENAI_API_KEY=
#   AGENTKIT_OPENAI_MODEL=

# ---- Web console security ---------------------------------------------------
# Auth is ON by default. Generate strong values, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AGENTKIT_WEB_AUTH_DISABLED=false
AGENTKIT_WEB_AUTH_TOKEN=
AGENTKIT_WEB_SECRET_KEY=
# Cookies are sent only over HTTPS when true. The compose stack serves plain
# HTTP on :8501, so this is false; set it to true once you put TLS in front.
AGENTKIT_WEB_COOKIE_SECURE=false

# ---- Runtime behaviour (sensible defaults) ----------------------------------
AGENTKIT_APPROVAL_CHECKPOINTER=sqlite
AGENTKIT_DETERMINISTIC_FASTPATH=true
AGENTKIT_COMBINED_INTENT_ROUTE=true

# ---- Long-term memory vector store (PostgreSQL + pgvector) -------------------
AGENTKIT_VECTOR_STORE_BACKEND=postgres
AGENTKIT_PG_DATABASE=agentkit
AGENTKIT_PG_USER=agentkit
# REQUIRED: the db service refuses to start without this. Use a strong value.
AGENTKIT_PG_PASSWORD=change-me-strong-password
# For docker-compose these are overridden to host=db / sslmode=disable; the
# values below apply to local (non-docker) runs against your own Postgres.
AGENTKIT_PG_HOST=localhost
AGENTKIT_PG_PORT=5432
AGENTKIT_PG_SSLMODE=disable

# Running locally WITHOUT a database? Comment out the postgres block above and
# use SQLite instead (zero external dependencies):
#   AGENTKIT_VECTOR_STORE_BACKEND=sqlite
