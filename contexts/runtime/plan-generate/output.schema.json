{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["goal", "steps"],
  "properties": {
    "goal": {"type": "string", "minLength": 1},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "skill", "args", "args_from", "depends_on", "strategy"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "skill": {"type": "string", "minLength": 1},
          "args": {"type": "object"},
          "args_from": {"type": "object", "additionalProperties": {"type": "string"}},
          "depends_on": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "strategy": {
            "type": ["string", "null"],
            "enum": ["direct", "workflow", "batch", "parallel", "react", "plan_execute", null]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
